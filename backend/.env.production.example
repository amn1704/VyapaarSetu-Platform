# Production Environment Variables
# Copy this to .env and fill in your values

# Database - Use PostgreSQL in production
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/vyapaarsetu

# Security - Generate a strong secret key
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - Set to your frontend Vercel URL
# Example: https://vyapaarsetu.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend-url.vercel.app

# AI/Ollama - keep disabled on Render unless you deploy a reachable Ollama service.
ENABLE_LLM=false
OLLAMA_HOST=
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# Matching Thresholds (tune based on your data quality)
AUTO_MATCH_THRESHOLD=0.85
REVIEW_QUEUE_THRESHOLD=0.60

# Vector Search
VECTOR_SEARCH_LIMIT=10
EMBEDDING_BATCH_SIZE=64
EMBEDDING_CONCURRENCY=4

# Celery (optional - for background tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Kafka (optional - for streaming)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Environment
DEBUG=false
LOG_LEVEL=INFO
